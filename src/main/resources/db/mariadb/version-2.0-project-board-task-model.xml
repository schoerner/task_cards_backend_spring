<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="version-2.0-create-role-tables" author="openai">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="roles"/>
            </not>
        </preConditions>

        <createTable tableName="roles">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(50)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_role_name"/>
            </column>
        </createTable>

        <createTable tableName="user_roles">
            <column name="user_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="role_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="user_roles" columnNames="user_id, role_id" constraintName="pk_user_roles"/>
        <addForeignKeyConstraint baseTableName="user_roles" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_user_roles_user" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="user_roles" baseColumnNames="role_id"
                                 referencedTableName="roles" referencedColumnNames="id"
                                 constraintName="fk_user_roles_role" onDelete="CASCADE"/>

        <insert tableName="roles">
            <column name="name" value="ROLE_USER"/>
        </insert>
        <insert tableName="roles">
            <column name="name" value="ROLE_ADMIN"/>
        </insert>
    </changeSet>

    <changeSet id="version-2.0-assign-default-user-role" author="openai">
        <sql>
            INSERT INTO user_roles (user_id, role_id)
            SELECT u.id, r.id
            FROM users u
            JOIN roles r ON r.name = 'ROLE_USER'
            WHERE NOT EXISTS (
                SELECT 1 FROM user_roles ur WHERE ur.user_id = u.id AND ur.role_id = r.id
            );
        </sql>
    </changeSet>

    <changeSet id="version-2.0-create-project-tables" author="openai">
        <createTable tableName="projects">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(150)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="varchar(5000)"/>
            <column name="archived" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="creator_user_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="projects" baseColumnNames="creator_user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_projects_creator_user"/>

        <createTable tableName="project_members">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="project_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="joined_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="project_members" columnNames="project_id,user_id" constraintName="uk_project_member"/>
        <addForeignKeyConstraint baseTableName="project_members" baseColumnNames="project_id"
                                 referencedTableName="projects" referencedColumnNames="id"
                                 constraintName="fk_project_members_project" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="project_members" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_project_members_user" onDelete="CASCADE"/>

        <createTable tableName="board_columns">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="project_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="position" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="varchar(20)" defaultValue="CUSTOM">
                <constraints nullable="false"/>
            </column>
            <column name="deletable" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="board_columns" baseColumnNames="project_id"
                                 referencedTableName="projects" referencedColumnNames="id"
                                 constraintName="fk_board_columns_project" onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="version-2.0-migrate-old-tasks-into-personal-projects" author="openai">
        <sql>
            INSERT INTO projects (name, description, archived, creator_user_id, created_at, updated_at)
            SELECT CONCAT('Migrated personal project - ', COALESCE(u.email, CONCAT('user-', u.id))),
                   'Automatisch aus dem Altmodell migriert',
                   FALSE,
                   u.id,
                   CURRENT_TIMESTAMP,
                   CURRENT_TIMESTAMP
            FROM users u
            WHERE EXISTS (SELECT 1 FROM tasks t WHERE t.creator_user_id = u.id)
              AND NOT EXISTS (
                    SELECT 1 FROM projects p
                    WHERE p.creator_user_id = u.id
                      AND p.name = CONCAT('Migrated personal project - ', COALESCE(u.email, CONCAT('user-', u.id)))
              );
        </sql>

        <sql>
            INSERT INTO project_members (project_id, user_id, role, joined_at)
            SELECT p.id, p.creator_user_id, 'OWNER', CURRENT_TIMESTAMP
            FROM projects p
            WHERE p.name LIKE 'Migrated personal project - %'
              AND NOT EXISTS (
                    SELECT 1 FROM project_members pm
                    WHERE pm.project_id = p.id AND pm.user_id = p.creator_user_id
              );
        </sql>

        <sql>
            INSERT INTO board_columns (project_id, name, position, type, deletable)
            SELECT p.id, 'Not assigned', 0, 'SYSTEM', FALSE
            FROM projects p
            WHERE p.name LIKE 'Migrated personal project - %'
              AND NOT EXISTS (
                    SELECT 1 FROM board_columns bc WHERE bc.project_id = p.id AND bc.name = 'Not assigned'
              );
        </sql>
        <sql>
            INSERT INTO board_columns (project_id, name, position, type, deletable)
            SELECT p.id, 'To do', 1, 'SYSTEM', TRUE
            FROM projects p
            WHERE p.name LIKE 'Migrated personal project - %'
              AND NOT EXISTS (
                    SELECT 1 FROM board_columns bc WHERE bc.project_id = p.id AND bc.name = 'To do'
              );
        </sql>
        <sql>
            INSERT INTO board_columns (project_id, name, position, type, deletable)
            SELECT p.id, 'In Progress', 2, 'SYSTEM', TRUE
            FROM projects p
            WHERE p.name LIKE 'Migrated personal project - %'
              AND NOT EXISTS (
                    SELECT 1 FROM board_columns bc WHERE bc.project_id = p.id AND bc.name = 'In Progress'
              );
        </sql>
        <sql>
            INSERT INTO board_columns (project_id, name, position, type, deletable)
            SELECT p.id, 'Done', 3, 'SYSTEM', FALSE
            FROM projects p
            WHERE p.name LIKE 'Migrated personal project - %'
              AND NOT EXISTS (
                    SELECT 1 FROM board_columns bc WHERE bc.project_id = p.id AND bc.name = 'Done'
              );
        </sql>
    </changeSet>

    <changeSet id="version-2.0-extend-tasks-table" author="openai">
        <addColumn tableName="tasks">
            <column name="project_id" type="bigint"/>
            <column name="board_column_id" type="bigint"/>
            <column name="priority" type="varchar(20)" defaultValue="MEDIUM"/>
            <column name="due_date" type="timestamp"/>
            <column name="archived" type="boolean" defaultValueBoolean="false"/>
            <column name="estimated_minutes" type="int" defaultValueNumeric="0"/>
            <column name="tracked_minutes" type="int" defaultValueNumeric="0"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </addColumn>

        <sql>
            UPDATE tasks t
                JOIN users u ON u.id = t.creator_user_id
                JOIN projects p ON p.creator_user_id = u.id
                AND p.name = CONCAT('Migrated personal project - ', COALESCE(u.email, CONCAT('user-', u.id)))
                JOIN board_columns bc ON bc.project_id = p.id AND bc.name = 'Not assigned'
                SET t.project_id = p.id,
                    t.board_column_id = bc.id,
                    t.priority = 'MEDIUM',
                    t.archived = FALSE,
                    t.estimated_minutes = 0,
                    t.tracked_minutes = COALESCE((
                    SELECT SUM(TIMESTAMPDIFF(MINUTE, tr.time_start, tr.time_end))
                    FROM time_records tr
                    WHERE tr.task_id = t.id
                    AND tr.time_start IS NOT NULL
                    AND tr.time_end IS NOT NULL
                    ), 0),
                    t.created_at = CURRENT_TIMESTAMP,
                    t.updated_at = CURRENT_TIMESTAMP
            WHERE t.project_id IS NULL OR t.board_column_id IS NULL;
        </sql>

        <addNotNullConstraint tableName="tasks" columnName="project_id" columnDataType="bigint"/>
        <addNotNullConstraint tableName="tasks" columnName="board_column_id" columnDataType="bigint"/>
        <addNotNullConstraint tableName="tasks" columnName="priority" columnDataType="varchar(20)"/>
        <addNotNullConstraint tableName="tasks" columnName="archived" columnDataType="boolean"/>
        <addNotNullConstraint tableName="tasks" columnName="estimated_minutes" columnDataType="int"/>
        <addNotNullConstraint tableName="tasks" columnName="tracked_minutes" columnDataType="int"/>
        <addNotNullConstraint tableName="tasks" columnName="created_at" columnDataType="timestamp"/>
        <addNotNullConstraint tableName="tasks" columnName="updated_at" columnDataType="timestamp"/>

        <addForeignKeyConstraint baseTableName="tasks" baseColumnNames="project_id"
                                 referencedTableName="projects" referencedColumnNames="id"
                                 constraintName="fk_tasks_project" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="tasks" baseColumnNames="board_column_id"
                                 referencedTableName="board_columns" referencedColumnNames="id"
                                 constraintName="fk_tasks_board_column"/>
    </changeSet>

    <changeSet id="version-2.0-create-task-support-tables" author="openai">
        <createTable tableName="task_labels">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="project_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="color" type="varchar(30)"/>
        </createTable>
        <addUniqueConstraint tableName="task_labels" columnNames="project_id,name" constraintName="uk_project_label_name"/>
        <addForeignKeyConstraint baseTableName="task_labels" baseColumnNames="project_id"
                                 referencedTableName="projects" referencedColumnNames="id"
                                 constraintName="fk_task_labels_project" onDelete="CASCADE"/>

        <createTable tableName="task_assignees">
            <column name="task_id" type="bigint"><constraints nullable="false"/></column>
            <column name="user_id" type="bigint"><constraints nullable="false"/></column>
        </createTable>
        <addPrimaryKey tableName="task_assignees" columnNames="task_id,user_id" constraintName="pk_task_assignees"/>
        <addForeignKeyConstraint baseTableName="task_assignees" baseColumnNames="task_id"
                                 referencedTableName="tasks" referencedColumnNames="id"
                                 constraintName="fk_task_assignees_task" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="task_assignees" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_task_assignees_user" onDelete="CASCADE"/>

        <createTable tableName="task_labels_map">
            <column name="task_id" type="bigint"><constraints nullable="false"/></column>
            <column name="label_id" type="bigint"><constraints nullable="false"/></column>
        </createTable>
        <addPrimaryKey tableName="task_labels_map" columnNames="task_id,label_id" constraintName="pk_task_labels_map"/>
        <addForeignKeyConstraint baseTableName="task_labels_map" baseColumnNames="task_id"
                                 referencedTableName="tasks" referencedColumnNames="id"
                                 constraintName="fk_task_labels_map_task" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="task_labels_map" baseColumnNames="label_id"
                                 referencedTableName="task_labels" referencedColumnNames="id"
                                 constraintName="fk_task_labels_map_label" onDelete="CASCADE"/>

        <createTable tableName="task_comments">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="task_id" type="bigint"><constraints nullable="false"/></column>
            <column name="author_user_id" type="bigint"><constraints nullable="false"/></column>
            <column name="content" type="varchar(10000)"><constraints nullable="false"/></column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
        </createTable>
        <addForeignKeyConstraint baseTableName="task_comments" baseColumnNames="task_id"
                                 referencedTableName="tasks" referencedColumnNames="id"
                                 constraintName="fk_task_comments_task" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="task_comments" baseColumnNames="author_user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_task_comments_author"/>

        <createTable tableName="task_attachments">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="task_id" type="bigint"><constraints nullable="false"/></column>
            <column name="original_filename" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="storage_path" type="varchar(500)"><constraints nullable="false"/></column>
            <column name="file_size_bytes" type="bigint"><constraints nullable="false"/></column>
            <column name="content_type" type="varchar(150)"/>
            <column name="uploaded_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
        </createTable>
        <addForeignKeyConstraint baseTableName="task_attachments" baseColumnNames="task_id"
                                 referencedTableName="tasks" referencedColumnNames="id"
                                 constraintName="fk_task_attachments_task" onDelete="CASCADE"/>

        <createTable tableName="task_subtasks">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="task_id" type="bigint"><constraints nullable="false"/></column>
            <column name="title" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="completed" type="boolean" defaultValueBoolean="false"><constraints nullable="false"/></column>
            <column name="position" type="int" defaultValueNumeric="0"><constraints nullable="false"/></column>
        </createTable>
        <addForeignKeyConstraint baseTableName="task_subtasks" baseColumnNames="task_id"
                                 referencedTableName="tasks" referencedColumnNames="id"
                                 constraintName="fk_task_subtasks_task" onDelete="CASCADE"/>

        <createTable tableName="task_dependencies">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="blocking_task_id" type="bigint"><constraints nullable="false"/></column>
            <column name="blocked_task_id" type="bigint"><constraints nullable="false"/></column>
        </createTable>
        <addUniqueConstraint tableName="task_dependencies" columnNames="blocking_task_id,blocked_task_id" constraintName="uk_task_dependency"/>
        <addForeignKeyConstraint baseTableName="task_dependencies" baseColumnNames="blocking_task_id"
                                 referencedTableName="tasks" referencedColumnNames="id"
                                 constraintName="fk_task_dependencies_blocking" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="task_dependencies" baseColumnNames="blocked_task_id"
                                 referencedTableName="tasks" referencedColumnNames="id"
                                 constraintName="fk_task_dependencies_blocked" onDelete="CASCADE"/>

        <createTable tableName="task_activities">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="task_id" type="bigint"><constraints nullable="false"/></column>
            <column name="created_by_user_id" type="bigint"/>
            <column name="type" type="varchar(40)"><constraints nullable="false"/></column>
            <column name="message" type="varchar(4000)"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
        </createTable>
        <addForeignKeyConstraint baseTableName="task_activities" baseColumnNames="task_id"
                                 referencedTableName="tasks" referencedColumnNames="id"
                                 constraintName="fk_task_activities_task" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="task_activities" baseColumnNames="created_by_user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_task_activities_created_by"/>

        <createTable tableName="task_recurrence_rules">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="task_id" type="bigint"><constraints nullable="false"/></column>
            <column name="frequency" type="varchar(20)"><constraints nullable="false"/></column>
            <column name="interval_value" type="int" defaultValueNumeric="1"><constraints nullable="false"/></column>
            <column name="next_execution_at" type="timestamp"/>
            <column name="active" type="boolean" defaultValueBoolean="true"><constraints nullable="false"/></column>
            <column name="custom_cron_expression" type="varchar(500)"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="task_recurrence_rules" baseColumnNames="task_id"
                                 referencedTableName="tasks" referencedColumnNames="id"
                                 constraintName="fk_task_recurrence_rules_task" onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="version-2.0-create-user-profiles" author="openai">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="user_profiles"/>
            </not>
        </preConditions>

        <createTable tableName="user_profiles">
            <column name="user_id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)"/>
            <column name="contact_email" type="VARCHAR(255)"/>
            <column name="picture_url" type="VARCHAR(1000)"/>
            <column name="description" type="VARCHAR(2000)"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="user_profiles"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_user_profiles_user"
                onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
