<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="0.3.1-task-polls" author="openai">
        <createTable tableName="task_polls">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="task_id" type="BIGINT"><constraints nullable="false" unique="true"/></column>
            <column name="created_by_user_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="title" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="description" type="MEDIUMTEXT"/>
            <column name="start_date" type="DATE"><constraints nullable="false"/></column>
            <column name="end_date" type="DATE"><constraints nullable="false"/></column>
            <column name="day_start_time" type="TIME"><constraints nullable="false"/></column>
            <column name="day_end_time" type="TIME"><constraints nullable="false"/></column>
            <column name="slot_minutes" type="INT"><constraints nullable="false"/></column>
            <column name="status" type="VARCHAR(20)" defaultValue="OPEN"><constraints nullable="false"/></column>
            <column name="finalized_start_at" type="TIMESTAMP"/>
            <column name="finalized_end_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
        </createTable>
        <addForeignKeyConstraint baseTableName="task_polls" baseColumnNames="task_id" referencedTableName="tasks" referencedColumnNames="id" constraintName="fk_task_polls_task"/>
        <addForeignKeyConstraint baseTableName="task_polls" baseColumnNames="created_by_user_id" referencedTableName="users" referencedColumnNames="id" constraintName="fk_task_polls_creator"/>
    </changeSet>

    <changeSet id="0.3.2-task-poll-dates" author="openai">
        <createTable tableName="task_poll_dates">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="poll_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="poll_date" type="DATE"><constraints nullable="false"/></column>
        </createTable>
        <addForeignKeyConstraint baseTableName="task_poll_dates" baseColumnNames="poll_id" referencedTableName="task_polls" referencedColumnNames="id" constraintName="fk_task_poll_dates_poll"/>
    </changeSet>

    <changeSet id="0.3.3-task-poll-participants" author="openai">
        <createTable tableName="task_poll_participants">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="poll_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="user_id" type="BIGINT"/>
            <column name="external_email" type="VARCHAR(255)"/>
            <column name="display_name" type="VARCHAR(255)"/>
            <column name="response_name" type="VARCHAR(255)"/>
            <column name="invitation_token_hash" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
            <column name="invited_at" type="TIMESTAMP"/>
            <column name="responded_at" type="TIMESTAMP"/>
            <column name="last_reminder_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="task_poll_participants" baseColumnNames="poll_id" referencedTableName="task_polls" referencedColumnNames="id" constraintName="fk_task_poll_participants_poll"/>
        <addForeignKeyConstraint baseTableName="task_poll_participants" baseColumnNames="user_id" referencedTableName="users" referencedColumnNames="id" constraintName="fk_task_poll_participants_user"/>
    </changeSet>

    <changeSet id="0.3.4-task-poll-availabilities" author="openai">
        <createTable tableName="task_poll_availabilities">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="participant_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="slot_start_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="availability" type="VARCHAR(20)"><constraints nullable="false"/></column>
        </createTable>
        <addForeignKeyConstraint baseTableName="task_poll_availabilities" baseColumnNames="participant_id" referencedTableName="task_poll_participants" referencedColumnNames="id" constraintName="fk_task_poll_availabilities_participant"/>
        <addUniqueConstraint tableName="task_poll_availabilities" columnNames="participant_id,slot_start_at" constraintName="uk_task_poll_availabilities_participant_slot"/>
    </changeSet>

</databaseChangeLog>
